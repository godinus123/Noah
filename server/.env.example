# NOAH Server v0.1 Configuration

# 서버 포트
PORT=3001

# JWT 시크릿 (반드시 변경)
JWT_SECRET=change-this-to-random-string-in-production

# Anthropic API (AI 봇)
# CPA Neowine: https://cpa.neowine.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://cpa.neowine.com/v1
AI_MODEL=claude-sonnet-4-6

# 로그 레벨
LOG_LEVEL=info
