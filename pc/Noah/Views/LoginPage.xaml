<Window x:Class="Noah.Views.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="NOAH - 로그인" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40">
            <!-- Logo -->
            <TextBlock Text="NOAH" FontSize="48" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#3B82F6"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Networked Operations Agent Hub" FontSize="12"
                       HorizontalAlignment="Center" Foreground="#888"
                       Margin="0,0,0,40"/>

            <!-- Username -->
            <TextBlock Text="사용자 이름" FontSize="13" Margin="0,0,0,4" Foreground="#333"/>
            <hc:TextBox x:Name="TxtUsername" hc:InfoElement.Placeholder="username"
                        FontSize="14" Margin="0,0,0,16"/>

            <!-- Password -->
            <TextBlock Text="비밀번호" FontSize="13" Margin="0,0,0,4" Foreground="#333"/>
            <PasswordBox x:Name="TxtPassword" FontSize="14" Margin="0,0,0,8"
                         Padding="8" />

            <!-- Error -->
            <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <!-- Login Button -->
            <Button x:Name="BtnLogin" Content="로그인" FontSize="15" Height="42"
                    Click="BtnLogin_Click"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,0,12"/>

            <!-- Skip login -->
            <Button Content="인증 없이 들어가기" FontSize="13" Height="36"
                    Click="BtnSkipLogin_Click"
                    Background="#9CA3AF" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,0,12"/>

            <!-- Register Link -->
            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                <Run Text="계정이 없으신가요? " Foreground="#666"/>
                <Hyperlink x:Name="LinkRegister" Click="LinkRegister_Click"
                           Foreground="#3B82F6">가입하기</Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <hc:LoadingCircle/>
                <TextBlock Text="로그인 중..." Margin="0,12,0,0" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
