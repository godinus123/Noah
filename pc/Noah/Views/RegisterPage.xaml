<Window x:Class="Noah.Views.RegisterPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="NOAH - 가입" Height="560" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40">
            <TextBlock Text="NOAH" FontSize="48" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#3B82F6"
                       Margin="0,0,0,8"/>
            <TextBlock Text="새 계정 만들기" FontSize="14"
                       HorizontalAlignment="Center" Foreground="#888"
                       Margin="0,0,0,40"/>

            <TextBlock Text="사용자 이름 *" FontSize="13" Margin="0,0,0,4" Foreground="#333"/>
            <hc:TextBox x:Name="TxtUsername" hc:InfoElement.Placeholder="2~30자"
                        FontSize="14" Margin="0,0,0,16"/>

            <TextBlock Text="표시 이름" FontSize="13" Margin="0,0,0,4" Foreground="#333"/>
            <hc:TextBox x:Name="TxtDisplayName" hc:InfoElement.Placeholder="(선택) 채팅에서 보여질 이름"
                        FontSize="14" Margin="0,0,0,16"/>

            <TextBlock Text="비밀번호 *" FontSize="13" Margin="0,0,0,4" Foreground="#333"/>
            <PasswordBox x:Name="TxtPassword" FontSize="14" Margin="0,0,0,8"
                         Padding="8"/>

            <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <Button x:Name="BtnRegister" Content="가입하기" FontSize="15" Height="42"
                    Click="BtnRegister_Click"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,0,12"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                <Run Text="이미 계정이 있으신가요? " Foreground="#666"/>
                <Hyperlink x:Name="LinkLogin" Click="LinkLogin_Click"
                           Foreground="#3B82F6">로그인</Hyperlink>
            </TextBlock>
        </StackPanel>

        <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <hc:LoadingCircle/>
                <TextBlock Text="가입 중..." Margin="0,12,0,0" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
