<Window x:Class="Noah.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="NOAH - 설정" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <StackPanel Margin="24">
        <TextBlock Text="설정" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="서버 주소" FontSize="13" Margin="0,0,0,4"/>
        <hc:TextBox x:Name="TxtServerUrl" FontSize="13" Margin="0,0,0,16"/>

        <TextBlock Text="기본 저장 폴더" FontSize="13" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <hc:TextBox x:Name="TxtSaveFolder" FontSize="13" IsReadOnly="True"/>
            <Button Grid.Column="1" Content="..." Width="36" Margin="8,0,0,0"
                    Click="BtnBrowse_Click"/>
        </Grid>

        <Button Content="저장" Height="36" Background="#3B82F6" Foreground="White"
                FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                Click="BtnSave_Click"/>
    </StackPanel>
</Window>
