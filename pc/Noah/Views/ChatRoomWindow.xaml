<Window x:Class="Noah.Views.ChatRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="NOAH" Height="600" Width="450"
        MinWidth="350" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Closing="OnClosing" AllowDrop="True"
        Drop="OnDrop" DragOver="OnDragOver">
    <Grid Background="{DynamicResource ChatBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="12,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="36" Height="36" CornerRadius="18" Background="#E0E7FF" Margin="0,0,10,0">
                    <TextBlock x:Name="TxtAvatar" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#3B82F6"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtFriendName" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtFriendUsername" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer x:Name="MessageScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="12,8">
            <ItemsControl x:Name="MessageList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <!-- Outgoing (right) -->
                            <Border x:Name="MyBubble" CornerRadius="12,12,0,12"
                                    Padding="12,8" MaxWidth="300"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource MyMessageBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOutgoing}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0}'}"
                                               FontSize="10" Foreground="#999" HorizontalAlignment="Right"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Incoming (left) -->
                            <Border x:Name="OtherBubble" CornerRadius="12,12,12,0"
                                    Padding="12,8" MaxWidth="300"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource OtherMessageBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOutgoing}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsAi}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource AiMessageBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding FromUsername}" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#3B82F6"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0}'}"
                                               FontSize="10" Foreground="#999"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area -->
        <Border Grid.Row="2" Background="White" Padding="8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="+" FontSize="20" Width="36" Height="36"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnAttach_Click" ToolTip="파일 첨부"/>
                <TextBox x:Name="TxtInput" Grid.Column="1"
                         Style="{StaticResource ChatInput}"
                         KeyDown="TxtInput_KeyDown"
                         hc:InfoElement.Placeholder="메시지 입력..."/>
                <Button Grid.Column="2" Content="➤" Style="{StaticResource SendButton}"
                        Click="BtnSend_Click" Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
