<Window x:Class="Noah.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="NOAH" Height="600" Width="380"
        WindowStartupLocation="CenterScreen" MinWidth="320" MinHeight="400"
        Background="{DynamicResource SidebarBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3B82F6" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NOAH" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="TxtMyName" FontSize="12" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,6,0"/>
                    <Button Content="⚙" FontSize="16" Foreground="White" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Click="BtnSettings_Click"
                            ToolTip="설정" Padding="4"/>
                    <Button Content="↪" FontSize="16" Foreground="White" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Click="BtnLogout_Click"
                            ToolTip="로그아웃" Padding="4" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add Friend -->
        <Border Grid.Row="1" Padding="12,8" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <hc:TextBox x:Name="TxtAddFriend" hc:InfoElement.Placeholder="친구 추가 (사용자 이름)"
                            FontSize="13" VerticalContentAlignment="Center"
                            KeyDown="TxtAddFriend_KeyDown"/>
                <Button Grid.Column="1" Content="+" FontSize="18" Width="36" Height="36"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="8,0,0,0" Click="BtnAddFriend_Click"
                        ToolTip="친구 추가"/>
            </Grid>
        </Border>

        <!-- Friend List -->
        <ListBox x:Name="FriendList" Grid.Row="2" BorderThickness="0"
                 Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="FriendList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Avatar circle -->
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#E0E7FF">
                                <TextBlock Text="{Binding Username, Converter={x:Null}}"
                                           FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#3B82F6"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="DisplayName" TargetNullValue="{Binding Username}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                           Foreground="#888" TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding StatusMessage, Converter={x:Null}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="White" Padding="12,6">
            <TextBlock x:Name="TxtStatus" FontSize="11" Foreground="#888"/>
        </Border>
    </Grid>
</Window>
