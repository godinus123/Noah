<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ChatBackgroundColor">#1A1A2E</Color>
    <Color x:Key="MyMessageColor">#FFE812</Color>
    <Color x:Key="OtherMessageColor">#2D3748</Color>
    <Color x:Key="AiMessageColor">#1E3A2E</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#AAAAAA</Color>
    <Color x:Key="SidebarBackgroundColor">#16213E</Color>
    <Color x:Key="AccentColor">#60A5FA</Color>

    <SolidColorBrush x:Key="ChatBackgroundBrush" Color="{StaticResource ChatBackgroundColor}"/>
    <SolidColorBrush x:Key="MyMessageBrush" Color="{StaticResource MyMessageColor}"/>
    <SolidColorBrush x:Key="OtherMessageBrush" Color="{StaticResource OtherMessageColor}"/>
    <SolidColorBrush x:Key="AiMessageBrush" Color="{StaticResource AiMessageColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

</ResourceDictionary>
