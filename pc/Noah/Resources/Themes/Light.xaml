<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ChatBackgroundColor">#B2C7D9</Color>
    <Color x:Key="MyMessageColor">#FFE812</Color>
    <Color x:Key="OtherMessageColor">#FFFFFF</Color>
    <Color x:Key="AiMessageColor">#E8F5E9</Color>
    <Color x:Key="TextPrimaryColor">#000000</Color>
    <Color x:Key="TextSecondaryColor">#666666</Color>
    <Color x:Key="SidebarBackgroundColor">#F5F5F5</Color>
    <Color x:Key="AccentColor">#3B82F6</Color>

    <SolidColorBrush x:Key="ChatBackgroundBrush" Color="{StaticResource ChatBackgroundColor}"/>
    <SolidColorBrush x:Key="MyMessageBrush" Color="{StaticResource MyMessageColor}"/>
    <SolidColorBrush x:Key="OtherMessageBrush" Color="{StaticResource OtherMessageColor}"/>
    <SolidColorBrush x:Key="AiMessageBrush" Color="{StaticResource AiMessageColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

</ResourceDictionary>
